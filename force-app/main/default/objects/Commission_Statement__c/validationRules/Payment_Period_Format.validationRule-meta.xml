<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Payment_Period_Format</fullName>
    <active>true</active>
    <errorConditionFormula>NOT( REGEX(Payment_Period__c, &quot;20\\d\\d-(0[1-9]|1[0-2])&quot;) )</errorConditionFormula>
    <errorDisplayField>Payment_Period__c</errorDisplayField>
    <errorMessage>Payment Period must be in YYYY-MM format (e.g., 2025-06).</errorMessage>
</ValidationRule>
